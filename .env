# cmake GPU backend flags — one variable per checkout
CMAKE_VULKAN_FLAGS="-DGGML_VULKAN=ON"
CMAKE_ROCM_FLAGS="-DGGML_HIP=ON -DCMAKE_PREFIX_PATH=/opt/rocm-7.2.1 -DCMAKE_EXE_LINKER_FLAGS=-no-pie -DAMDGPU_TARGETS=gfx1201 -DGGML_CUDA_FORCE_MMQ=ON"

# llama-server flags
SERVER_FLAGS_COMMON="--host 0.0.0.0 --models-preset models.ini --models-max 1 --webui-mcp-proxy"
SERVER_FLAGS_VULKAN=""
SERVER_FLAGS_ROCM=""
